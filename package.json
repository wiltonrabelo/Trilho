{
  "name": "trilho",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Trilho — visualizador e cliente Git minimalista para a trilha de commits.",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "test:rust": "npm run test:clippy && cargo test --manifest-path src-tauri/Cargo.toml",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "audit": "npm audit --audit-level=high && cargo audit --manifest-path src-tauri/Cargo.toml",
    "build:win": "npm run tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tauri-apps/cli": "^2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "@playwright/test": "^1.49.1"
  }
}
